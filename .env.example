# --- Veritabanı (PostgreSQL zorunlu; Supabase veya Docker) ---
# Yerel Docker: npm run db:up → aşağıdaki iki satır aynı olabilir
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/laperla"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/laperla"

# Supabase: Settings → Database
# - Uygulama / pooler (Transaction) → DATABASE_URL (pgbouncer=true ekli olabilir)
# - Session veya doğrudan (port 5432) → DIRECT_URL (migrate / prisma migrate deploy için)
# Örnek pooler:
# DATABASE_URL="postgresql://postgres.[ref]:[ŞİFRE]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[ŞİFRE]@db.[ref].supabase.co:5432/postgres"

# JWT oturumu — üretimde zorunlu, en az 16 karakter
AUTH_SECRET="yerel-gelistirme-icin-en-az-16-ch"

# Supabase Storage (Vercel’de ürün görseli yükleme; boşsa yerel public/uploads kullanılır)
# Dashboard → Storage → bucket oluştur: product-images → Public bucket
# NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=""
# İsteğe bağlı bucket adı (varsayılan product-images)
# SUPABASE_STORAGE_BUCKET="product-images"

# İşletme (KVKK / mesafeli satış / footer) — ayrıntı: docs/ISLETME_KONTROL_LISTESI.md
# SITE_LEGAL_NAME="Örnek Ticaret A.Ş."
# SITE_TRADE_NAME="La Perla"
# SITE_ADDRESS="Mahalle, cadde no\nİlçe / İl"
# SITE_PHONE="+90 555 123 45 67"
# SITE_CONTACT_EMAIL="info@ornek.com"
# SITE_MERSIS="1234567890123456"
# NEXT_PUBLIC_WHATSAPP_E164="905551234567"

# Google Identity Services — ikisi de aynı Web Client ID (Console’da “Web application”)
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# Vercel: Environment Variables’a ekleyin; OAuth Console’da Authorized origins = üretim URL + localhost

# Kargo ücreti (kuruş; boş = 0)
# SHIPPING_CENTS="9900"
# Ücretsiz kargo: ara toplam (kuruş) bu tutara ulaşınca kargo 0 (boş = eşik yok)
# FREE_SHIPPING_SUBTOTAL_CENTS="150000"

# Yönetici paneli (/admin/giris) — şifre değişince: npm run db:seed
ADMIN_SEED_EMAIL="admin@laperla.local"
ADMIN_SEED_PASSWORD="degistir-guclu-sifre"

# Site adresi (sitemap / canonical / Open Graph / şifre sıfırlama bağlantısı)
# Vercel’de Production URL ile doldurun
# NEXT_PUBLIC_SITE_URL="https://www.ornek.com"

# E-posta (şifre sıfırlama; boşsa geliştirmede konsola yazılır)
# RESEND_API_KEY=""
# MAIL_FROM="La Perla <noreply@sizin-domain.com>"
# MAIL_BRAND_NAME="La Perla"
# ORDER_NOTIFY_EMAIL="siparis@ornek.com"

# Canlı ödeme (iyzico vb.)
# IYZICO_API_KEY=""
# IYZICO_SECRET_KEY=""
